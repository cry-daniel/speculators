# Configuration for Qwen3-8B with P-EAGLE parallel drafting
# Evaluation on math_reasoning dataset
#
# Set QWEN3_8B_MODEL or PEAGLE_SPECULATOR_MODEL to override defaults.

# Model configuration
BASE_MODEL="${QWEN3_8B_MODEL:-Qwen/Qwen3-8B}"
SPECULATOR_MODEL="${PEAGLE_SPECULATOR_MODEL:-/ACALAB/stu1/chenruiyang/Code/LLM/SpecLink/models/qwen3-8b-peagle-speculator}"
NUM_SPEC_TOKENS=8
METHOD="eagle3"
PARALLEL_DRAFTING="true"

# Dataset configuration
DATASET="${MATH_REASONING_DATASET:-data/math_reasoning.jsonl}"

# vLLM server settings
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=24000
GPU_MEMORY_UTILIZATION=0.85
PORT=8000
HEALTH_CHECK_TIMEOUT=1800

# Sampling parameters
TEMPERATURE=0.6
TOP_P=0.95
TOP_K=20

# Output settings
OUTPUT_DIR="${RESULTS_DIR:-results}/eval_results_$(date +%Y%m%d_%H%M%S)"
